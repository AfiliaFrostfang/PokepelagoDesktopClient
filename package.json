{
  "name": "pokepelago",
  "private": true,
  "version": "0.6.3",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "cross-env VITE_DESKTOP=true npm run build && electron-builder"
  },
  "dependencies": {
    "@types/canvas-confetti": "1.9.0",
    "archipelago.js": "2.0.4",
    "canvas-confetti": "1.9.4",
    "clsx": "2.1.1",
    "idb": "8.0.3",
    "lucide-react": "0.574.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0",
    "tmi.js": "1.8.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@tailwindcss/postcss": "4.2.1",
    "@tailwindcss/vite": "4.2.1",
    "@types/node": "24.10.14",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/tmi.js": "1.8.6",
    "@vitejs/plugin-react": "5.1.4",
    "autoprefixer": "10.4.27",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "eslint": "9.39.3",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "globals": "16.5.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "^7.3.6",
    "vitest": "4.1.5",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "com.dowlle.pokepelago",
    "productName": "Pokepelago Client",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "allowScripts": {
    "electron@43.1.0": true,
    "esbuild@0.28.1": true
  }
}
